<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ fine-grained backup rules.
  We exclude SharedPreferences and database files from cloud backup
  to protect user academic data (timetable, attendance, grades).
  The in-app backup/restore feature handles data migration explicitly.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="classflow_prefs.xml"/>
        <exclude domain="database" path="classflow_database"/>
        <exclude domain="database" path="classflow_database-shm"/>
        <exclude domain="database" path="classflow_database-wal"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="classflow_prefs.xml"/>
        <exclude domain="database" path="classflow_database"/>
    </device-transfer>
</data-extraction-rules>
