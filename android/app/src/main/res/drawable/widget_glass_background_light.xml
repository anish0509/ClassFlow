<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. Frosted base: high-translucency neutral light glass (40% down to 25% opacity) -->
    <item>
        <shape>
            <gradient
                android:startColor="#66FFFFFF"
                android:centerColor="#45FFFFFF"
                android:endColor="#28FFFFFF"
                android:angle="270" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- 2. Speclar glossy shine (top-left specular light reflection) -->
    <item>
        <shape>
            <gradient
                android:startColor="#45FFFFFF"
                android:centerColor="#0EFFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="300" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- 3. Crisp outer border for outline definition on light backgrounds -->
    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#40000000" />
        </shape>
    </item>

</layer-list>
